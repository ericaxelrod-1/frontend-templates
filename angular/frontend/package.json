{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs",
    "start:maildev": "node server/email-service/start-maildev.js",
    "start:email-dev": "concurrently \"npm run start:maildev\" \"npm run serve:ssr:frontend\"",
    "lint:styles": "stylelint \"src/**/*.scss\" --fix",
    "test:styles": "stylelint \"src/**/*.scss\"",
    "check:duplicate-css": "node tools/check-duplicate-css.js",
    "check:material-theme": "node tools/validate-material-theme.js",
    "check:layout-nesting": "node tools/check-layout-nesting.js",
    "verify:styles": "npm run lint:styles && npm run check:duplicate-css && npm run check:material-theme",
    "verify:layouts": "npm run check:layout-nesting",
    "verify": "npm run verify:styles && npm run verify:layouts && ng build",
    "security:audit": "node tools/security-audit.js",
    "security:audit:fix": "node tools/security-audit.js --fix",
    "security:audit:report": "node tools/security-audit.js --report",
    "security:full": "node tools/security-audit.js --fix --report",
    "security:schedule": "node tools/schedule-security-audit.js",
    "security-test": "node server/email-service/test/security-tests.js",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "18.2.13",
    "@angular/cdk": "^18.2.13",
    "@angular/common": "18.2.13",
    "@angular/core": "18.2.13",
    "@angular/forms": "18.2.13",
    "@angular/material": "18.2.13",
    "@angular/platform-server": "18.2.13",
    "@angular/router": "18.2.13",
    "@angular/ssr": "^18.2.20",
    "@casl/ability": "^6.8.1",
    "@casl/angular": "^9.0.6",
    "@ngxs/devtools-plugin": "18.1.6",
    "@ngxs/form-plugin": "18.1.6",
    "@ngxs/router-plugin": "18.1.6",
    "@ngxs/store": "18.1.6",
    "express": "^4.18.2",
    "express-rate-limit": "7.1.5",
    "ng-diagram": "^1.1.2",
    "nodemailer": "6.9.12",
    "rxjs": "7.8.1",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "18.2.20",
    "@angular/cli": "18.2.20",
    "@angular/compiler": "^18.2.13",
    "@angular/compiler-cli": "18.2.13",
    "@angular/platform-browser": "^18.2.13",
    "@angular/platform-browser-dynamic": "^18.2.13",
    "@types/express": "^4.17.17",
    "@types/jasmine": "^5.1.4",
    "@types/node": "20.11.30",
    "angular-eslint": "19.3.0",
    "concurrently": "8.2.2",
    "eslint": "^9.23.0",
    "glob": "10.3.10",
    "jasmine-core": "^6.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "maildev": "2.2.1",
    "stylelint": "15.11.0",
    "typescript": "5.4.2",
    "typescript-eslint": "8.27.0"
  }
}
