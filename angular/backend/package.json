{
  "name": "task-management-backend",
  "version": "0.0.1",
  "description": "Task Management Backend",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:custom": "tsc && node --trace-warnings dist/src/main.js",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --max-old-space-size=128 dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "privacy:rotate-pepper": "ts-node -r tsconfig-paths/register src/modules/privacy/scripts/rotate-pepper.ts",
    "generate:privacy-policy": "ts-node -r tsconfig-paths/register src/modules/privacy/scripts/generate-policy.ts",
    "test:login-monitoring": "ts-node -r tsconfig-paths/register src/scripts/test-login-monitoring.ts",
    "test:ip-allowlist": "ts-node -r tsconfig-paths/register src/scripts/test-ip-allowlist.ts",
    "test:ip-allowlist:detailed": "ts-node -r tsconfig-paths/register src/scripts/test-ip-allowlist-detailed.ts",
    "test:gmail": "ts-node -r tsconfig-paths/register src/scripts/test-gmail-delivery.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d ./src/database/data-source.ts",
    "migration:run": "cross-env TS_NODE_CACHE=false ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./src/database/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d ./src/database/data-source.ts",
    "migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create",
    "migration:fix-sqlite": "ts-node -r tsconfig-paths/register src/scripts/run-migrations.ts",
    "migration:run-in-order": "ts-node -r tsconfig-paths/register src/scripts/run-migrations-in-order.ts",
    "db:prepare": "ts-node -r tsconfig-paths/register src/scripts/prepare-database.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "db:seed:permissions": "ts-node -r tsconfig-paths/register src/db/seeds/seed.ts",
    "sync:permissions-cache": "ts-node -r tsconfig-paths/register src/scripts/sync-permissions-cache.ts",
    "permissions:scan": "ts-node -r tsconfig-paths/register ./src/scripts/scan-permissions.ts",
    "permissions:check-deps": "node check-dependencies.js",
    "db:schema:sync": "ts-node -r tsconfig-paths/register ./src/database/schema-sync.ts",
    "db:create": "ts-node -r tsconfig-paths/register ./src/scripts/create-db.ts",
    "migrate-roles": "ts-node -r tsconfig-paths/register src/scripts/migrate-roles.ts",
    "seed-roles": "ts-node -r tsconfig-paths/register src/scripts/seed-roles.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.8.1",
    "@fastify/static": "^8.3.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.20",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.1.4",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^5.1.1",
    "cache-manager": "^6.4.2",
    "canvas": "^3.2.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.2",
    "geoip-lite": "^2.0.0",
    "glob": "^11.0.1",
    "nestjs-cls": "^6.2.0",
    "nodemailer": "^6.9.13",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.23",
    "typeorm-naming-strategies": "^4.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.24",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
