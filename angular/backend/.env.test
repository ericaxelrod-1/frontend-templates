# Test environment configuration
PORT=3000
NODE_ENV=test

# Use in-memory SQLite for testing
DB_TYPE=sqlite
DATABASE_FILE=:memory:
DB_SYNCHRONIZE=true

# JWT configuration
JWT_SECRET=test_jwt_secret_key
JWT_EXPIRES_IN=1h

# IP Allowlist settings for testing
IP_ALLOWLIST=192.168.1.100,10.0.0.1

# Disable debug logging for tests
DEBUG_MODE=false
LOG_TO_FILE=false

# Security settings
MAX_FAILED_ATTEMPTS=5
BLOCK_DURATION_MINUTES=30
CAPTCHA_THRESHOLD=3

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Email Configuration
EMAIL_ENABLED=true
APP_NAME="Angular App"
EMAIL_PROVIDER=nodemailer
FRONTEND_URL=http://localhost:4200

# Nodemailer
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=