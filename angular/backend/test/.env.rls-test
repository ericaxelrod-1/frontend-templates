# RLS E2E Test environment configuration
PORT=3001
NODE_ENV=rls-test

# Use file-based SQLite for RLS tests (not :memory:)
DB_TYPE=sqlite
DB_DATABASE=./test/rls-test.sqlite

# JWT configuration
JWT_SECRET=test_jwt_secret_key_rls
JWT_EXPIRES_IN=1h

# IP Allowlist settings for testing
IP_ALLOWLIST=192.168.1.100,10.0.0.1

# Disable debug logging for tests
DEBUG_MODE=false
LOG_TO_FILE=false

# Security settings
MAX_FAILED_ATTEMPTS=5
BLOCK_DURATION_MINUTES=30
CAPTCHA_THRESHOLD=3

# Frontend URL
FRONTEND_URL=http://localhost:4200

# RLS settings
RLS_ENABLED=true
