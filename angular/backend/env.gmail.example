# Gmail SMTP Configuration for Real-World Testing
# Copy this to .env.gmail and fill in your details

NODE_ENV=development
EMAIL_ENABLED=true
EMAIL_PROVIDER=nodemailer
FRONTEND_URL=http://localhost:4200

# Gmail SMTP Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true

# YOUR GMAIL ADDRESS
EMAIL_USER=your-email@gmail.com

# YOUR GMAIL APP PASSWORD
# 1. Go to Google Account -> Security
# 2. Enable 2-Step Verification
# 3. Search for "App Passwords"
# 4. Create an app named "Angular App"
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# MUST match your Gmail address for best deliverability
EMAIL_FROM="Angular Test" <your-email@gmail.com>
