# Application settings
PORT=3000
NODE_ENV=development

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=task_management

# JWT configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1h

# IP Allowlist settings
# Comma-separated list of IP addresses that should bypass security restrictions
# Default: localhost (127.0.0.1) and IPv6 localhost (::1) are always included
IP_ALLOWLIST=192.168.1.100,10.0.0.1

# Logging settings
DEBUG_MODE=true
LOG_TO_FILE=true
LOG_DIR=logs

# Security settings
# Maximum failed login attempts before IP is blocked
MAX_FAILED_ATTEMPTS=5
# Duration (in minutes) to block an IP after exceeding MAX_FAILED_ATTEMPTS
BLOCK_DURATION_MINUTES=30
# Number of failed attempts before requiring CAPTCHA
CAPTCHA_THRESHOLD=3 