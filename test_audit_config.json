{
  "database": {
    "path": "./angular/backend/db.sqlite",
    "backup_directory": "./backup",
    "enable_foreign_keys": true
  },
  "entity_paths": [
    "./angular/backend/src/modules/**/entities/*.entity.ts",
    "./angular/backend/src/modules/**/entity/*.entity.ts"
  ],
  "migration_paths": [
    "./angular/backend/src/migrations/*.ts"
  ],
  "output": {
    "format": "json",
    "include_sql_fixes": true
  },
  "validation": {
    "check_missing_tables": true,
    "check_extra_tables": true,
    "check_column_types": true,
    "check_constraints": true,
    "check_foreign_keys": true
  },
  "logging": {
    "level": "INFO",
    "file": true,
    "console": true
  }
} 