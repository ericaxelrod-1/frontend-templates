{
  "database": {
    "sqlite": {
      "paths": [
        "db.sqlite",
        "database.sqlite",
        "./angular/backend/db.sqlite",
        "./angular/backend/database.sqlite"
      ],
      "default_path": "db.sqlite"
    },
    "postgres": {
      "enabled": false,
      "host": "localhost",
      "port": 5432,
      "username": "postgres",
      "password": "",
      "database": "angular_template"
    }
  },
  "validation": {
    "include_extra_tables": false,
    "include_extra_columns": false,
    "check_indexes": true,
    "check_constraints": true,
    "check_foreign_keys": true
  },
  "synchronization": {
    "auto_backup": true,
    "backup_dir": "./db_backups",
    "sync_command": "npm run db:schema:sync",
    "backend_dir": "./angular/backend"
  },
  "logging": {
    "level": "INFO",
    "file_enabled": true,
    "file_dir": "./logs",
    "console_enabled": true
  },
  "debugging": {
    "enabled": false,
    "log_queries": false,
    "verbose_output": false
  }
} 